<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Exercise 4: Spring Bean Configuration
        =======================================
        This file is the XML-based Spring Application Context configuration.
        It defines beans managed by the Spring IoC container and wires
        dependencies between them using setter-based Dependency Injection.
    -->

    <!-- Bean: BookRepository (Data Access Layer) -->
    <bean id="bookRepository" class="com.library.repository.BookRepository" />

    <!-- Bean: BookService (Service Layer)
         Injects BookRepository via the setBookRepository() setter method -->
    <bean id="bookService" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository" />
    </bean>

</beans>
